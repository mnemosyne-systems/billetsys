# Forgot password and CAPTCHA example configuration

# Public base URL used in password reset links
APP_PUBLIC_BASE_URL=http://localhost:8080

# CAP.js configuration
# Start the local CAP stack with: docker compose up -d
# Then create or inspect your site/app in the CAP dashboard and replace these placeholders.
CAP_API_ENDPOINT=http://localhost:3000/<your-cap-app-id>
CAP_SITEVERIFY_URL=http://localhost:3000/<your-cap-app-id>/siteverify
CAP_SECRET_KEY=<your-cap-secret-key>

# Mail configuration
# Use mocked mail locally unless you are intentionally testing SMTP delivery.
# Set MAIL_MOCK to false when testing real SMTP delivery.
MAIL_MOCK=true
MAIL_FROM=no-reply@example.com

# Real SMTP example
QUARKUS_MAILER_HOST=smtp.example.com
QUARKUS_MAILER_PORT=587
QUARKUS_MAILER_USERNAME=your-email@example.com
QUARKUS_MAILER_PASSWORD=<your-smtp-password-or-app-password>
QUARKUS_MAILER_START_TLS=REQUIRED
QUARKUS_MAILER_SSL=false
